# ─────────────────────────────────────────────────────────────
# PumpFun Telegram Bot — Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# ─────────────────────────────────────────────────────────────

# [WAJIB] Token bot dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# [WAJIB] Private key wallet Solana (base58 string ATAU JSON array)
# Contoh base58 : 5JD3HQn7...
# Contoh JSON   : [12,34,56,78,...]
# ⚠️  JANGAN pernah share private key ini ke siapapun!
WALLET_PRIVATE_KEY=your_solana_private_key_here

# [Opsional] Solana RPC URL — default: mainnet-beta publik
# Gunakan RPC privat (Helius/QuickNode) agar lebih cepat & stabil
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
